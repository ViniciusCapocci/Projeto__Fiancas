entradas = []
despesas = []

for i in range(3):
    valor = float(input("Digite um valor de entrada: "))
    entradas.append(valor)

for i in range(3):
    valor = float(input("Digite um valor de despesa: "))
    despesas.append(valor)

total_entradas = sum(entradas)
total_despesas = sum(despesas)

saldo = total_entradas - total_despesas

print("Total de entradas:", total_entradas)
print("Total de despesas:", total_despesas)
print("Saldo final:", saldo)